# Frontend (Vite) environment variables.
# Local: copy to `.env`. Production: set these in the Netlify dashboard
# (Site settings -> Environment variables).

# Base URL of the deployed backend API on Render — MUST include the trailing /api
# Local dev can leave this unset (defaults to http://localhost:5000/api).
VITE_API_URL=https://sawta-guest-house-api.onrender.com/api

# WhatsApp number for the floating button (country code + number, no +)
VITE_WHATSAPP=919876543210

# Google Maps embed URL for the location section
VITE_MAPS_EMBED=https://www.google.com/maps?q=Maharashtra%20India&output=embed
