# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/sawta_guest_house

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Default admin (created by `npm run seed`)
ADMIN_NAME=Sawta Admin
ADMIN_EMAIL=admin@sawtaguesthouse.com
ADMIN_PASSWORD=Admin@123

# Cloudinary (image & video storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Notifications (optional) — where new-booking alerts are emailed/logged
NOTIFY_EMAIL=owner@sawtaguesthouse.com

# Business identity (used in guest confirmation email + WhatsApp)
BUSINESS_NAME=Sawta Guest House
BUSINESS_PHONE=+91 98765 43210
MAIL_FROM_ADDRESS=stay@sawtaguesthouse.com

# === Guest confirmation EMAIL ===
# Priority: 1) Gmail API (below)  2) SMTP (further below)  3) console log only.
#
# --- Option 1: Gmail API (recommended) ---
# Setup: Google Cloud Console -> enable "Gmail API" -> create OAuth Client ID (Web app)
# -> add https://developers.google.com/oauthplayground as a redirect URI
# -> in OAuth Playground, authorize scope https://www.googleapis.com/auth/gmail.send
# and exchange for a refresh token. GMAIL_SENDER is the Gmail address that sends mail.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_SENDER=you@gmail.com

# --- Option 2: Generic SMTP (Nodemailer) fallback ---
# Leave SMTP_HOST blank to skip. Example for Gmail app password:
# SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=you@gmail.com SMTP_PASS=app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Sawta Guest House <stay@sawtaguesthouse.com>

# Guest confirmation WHATSAPP (Twilio). Leave blank to just log a click-to-send wa.me link instead of sending.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
